@model IEnumerable<CineAnimeWeb.Models.Genero>

@{
    ViewData["Title"] = "Generos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Generos</h1>
    <a class="btn btn-primary" asp-action="Create">Cadastrar genero</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Obras relacionadas</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Nome</td>
            <td>@item.ObraGeneros.Count</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Detalhes</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>
