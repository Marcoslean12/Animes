@model CineAnimeWeb.ViewModels.ObraFormViewModel

@{
    ViewData["Title"] = "Cadastrar Obra";
}

<div class="card shadow border-0">

    <div class="card-header bg-success text-white">
        <h3 class="mb-0">➕ Cadastrar Nova Obra</h3>
        <small>Preencha os dados para adicionar uma nova obra ao catálogo.</small>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post" class="row g-3">

            <partial name="_Form" model="Model" />

            <div class="col-12 border-top pt-3 mt-3">

                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-success">
                        💾 Salvar Obra
                    </button>

                    <a class="btn btn-secondary"
                       asp-action="Index">
                        ↩️ Voltar
                    </a>

                </div>

            </div>

        </form>

    </div>

    <div class="card-footer text-center text-muted">
        CineAnimeWeb • Cadastro de Obras
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
}
