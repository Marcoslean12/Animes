@model CineAnimeWeb.Models.Obra

@{
    ViewData["Title"] = "Detalhes da Obra";
}

<div class="card shadow border-0">

    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

        <div>
            <h3 class="mb-0">🎬 @Model.Titulo</h3>
            <small>Informações completas da obra</small>
        </div>

        <a class="btn btn-light fw-bold"
           asp-controller="Avaliacoes"
           asp-action="Create"
           asp-route-obraId="@Model.Id">
            ⭐ Avaliar Obra
        </a>

    </div>

    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <div class="card bg-light border-0">
                    <div class="card-body">

                        <h5 class="card-title">📋 Informações Gerais</h5>

                        <p>
                            <strong>Tipo:</strong>
                            <span class="badge bg-info text-dark">
                                @Model.Tipo
                            </span>
                        </p>

                        <p>
                            <strong>Ano de Lançamento:</strong>
                            @Model.AnoLancamento
                        </p>

                        <p>
                            <strong>Duração:</strong>
                            @Model.DuracaoMinutos minutos
                        </p>

                        <p>
                            <strong>Diretor/Estúdio:</strong><br />
                            @Model.DiretorEstudio?.Nome
                            <span class="text-muted">
                                (@Model.DiretorEstudio?.Pais)
                            </span>
                        </p>

                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card bg-light border-0">
                    <div class="card-body">

                        <h5 class="card-title">🏷️ Gêneros</h5>

                        @foreach (var genero in Model.ObraGeneros.Select(og => og.Genero?.Nome))
                        {
                            <span class="badge bg-secondary me-1 mb-1">
                                @genero
                            </span>
                        }

                    </div>
                </div>
            </div>

            <div class="col-12">

                <div class="card bg-light border-0">
                    <div class="card-body">

                        <h5 class="card-title">📖 Sinopse</h5>

                        <p class="mb-0">
                            @Model.Sinopse
                        </p>

                    </div>
                </div>

            </div>

        </div>

    </div>

</div>

<div class="card shadow border-0 mt-4">

    <div class="card-header bg-warning">
        <h4 class="mb-0 text-dark">
            ⭐ Avaliações da Obra
        </h4>
    </div>

    <div class="card-body">

        @if (Model.Avaliacoes.Any())
        {
            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>👤 Usuário</th>
                            <th>⭐ Nota</th>
                            <th>💬 Comentário</th>
                            <th>📅 Data</th>
                            <th class="text-center">⚙️ Ações</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var avaliacao in Model.Avaliacoes.OrderByDescending(a => a.DataAvaliacao))
                        {
                            <tr>

                                <td>
                                    <strong>@avaliacao.NomeUsuario</strong>
                                </td>

                                <td>
                                    <span class="badge bg-success fs-6">
                                        ⭐ @avaliacao.Nota.ToString("0.0")
                                    </span>
                                </td>

                                <td>
                                    @avaliacao.Comentario
                                </td>

                                <td>
                                    @avaliacao.DataAvaliacao.ToShortDateString()
                                </td>

                                <td class="text-center">

                                    <a class="btn btn-sm btn-danger"
                                       asp-controller="Avaliacoes"
                                       asp-action="Delete"
                                       asp-route-id="@avaliacao.Id">
                                        🗑️ Excluir
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="alert alert-info text-center mb-0">
                ℹ️ Nenhuma avaliação cadastrada para esta obra.
            </div>
        }

    </div>

</div>

<div class="d-flex justify-content-end gap-2 mt-4">

    <a class="btn btn-secondary"
       asp-action="Index">
        ↩️ Voltar
    </a>

    <a class="btn btn-warning"
       asp-action="Edit"
       asp-route-id="@Model.Id">
        ✏️ Editar
    </a>

</div>
