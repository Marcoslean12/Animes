@model CineAnimeWeb.Models.DiretorEstudio

@{
    ViewData["Title"] = "Detalhes";
}

<h1>@Model.Nome</h1>
<dl class="row">
    <dt class="col-sm-3">Pais</dt>
    <dd class="col-sm-9">@Model.Pais</dd>
</dl>

<h2 class="h4">Obras</h2>
@if (Model.Obras.Any())
{
    <ul>
    @foreach (var obra in Model.Obras.OrderBy(o => o.Titulo))
    {
        <li><a asp-controller="Obras" asp-action="Details" asp-route-id="@obra.Id">@obra.Titulo</a> (@obra.Tipo)</li>
    }
    </ul>
}
else
{
    <p>Nenhuma obra cadastrada para este diretor/estudio.</p>
}

<a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
<a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
